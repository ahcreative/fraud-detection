{
  "title": "Fraud Detection — Model Performance",
  "uid": "fraud-model-performance",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Fraud Recall",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "fraud_recall_current", "legendFormat": "Recall"}],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              {"color": "red",    "value": 0},
              {"color": "yellow", "value": 0.75},
              {"color": "green",  "value": 0.85}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "False Positive Rate",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "fraud_false_positive_rate", "legendFormat": "FPR"}],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              {"color": "green",  "value": 0},
              {"color": "yellow", "value": 0.1},
              {"color": "red",    "value": 0.15}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Fraud vs Legitimate Predictions",
      "type": "piechart",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
      "targets": [
        {"expr": "fraud_predictions_total{prediction='fraud'}", "legendFormat": "Fraud"},
        {"expr": "fraud_predictions_total{prediction='legitimate'}", "legendFormat": "Legitimate"}
      ]
    },
    {
      "id": 4,
      "title": "Model Version",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "fraud_model_version", "legendFormat": "Version"}]
    },
    {
      "id": 5,
      "title": "Fraud Detection Rate (per minute)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [
        {"expr": "rate(fraud_predictions_total{prediction='fraud'}[1m])", "legendFormat": "Fraud/min"},
        {"expr": "rate(fraud_predictions_total{prediction='legitimate'}[1m])", "legendFormat": "Legit/min"}
      ]
    },
    {
      "id": 6,
      "title": "Prediction Confidence Distribution",
      "type": "histogram",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [{"expr": "rate(fraud_prediction_confidence_bucket[5m])", "legendFormat": "{{le}}"}]
    }
  ]
}
